# AdaptiveTutor AI - Environment Variables Example
# Rename this file to .env and fill in the values

# Hugging Face Configuration
HUGGING_FACE_HUB_TOKEN=your_token_here

# OpenEnv Server Configuration
APP_HOST=0.0.0.0
APP_PORT=7860

# Model Configuration
AI_MODEL_NAME=Qwen/Qwen2.5-0.5B-Instruct
LAZY_LOAD_AI=True

# API Security (Optional)
API_TOKEN=your_custom_api_token_here
